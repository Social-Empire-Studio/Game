# MySQL / MariaDB connection
# Copy this file to ".env" and fill in YOUR values (from your host / phpMyAdmin panel).
#
# If you use a shared web host (cPanel / phpMyAdmin), the database name and user
# are usually shown in the hosting panel and often look like "myuser_socialemp".
# IMPORTANT: many shared hosts BLOCK remote MySQL connections. If the connection
# is refused, add your IP to "Remote MySQL" in the host panel, or run a local
# MySQL/MariaDB (e.g. XAMPP) instead.

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=social_empires

# Web server
PORT=3000
HOST=127.0.0.1

# Session secret (change this to any random string)
SESSION_SECRET=change_me_to_a_random_secret
