<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="utf-8"/>
		<title id="pageTitle">Social Empires</title>
		<link rel="shortcut icon" href="img/icon.gif"/>
		<link rel="icon" type="image/png" href="img/icon.gif"/>
		<link rel="stylesheet" href="css/facebook.css"/>
		<style>
			.auth-wrap { max-width: 420px; margin: 0 auto; text-align: left; font-size: 13px; }
			.auth-box { border: 1px solid #ccc; border-radius: 6px; padding: 16px; margin-bottom: 16px; background: #fafafa; }
			.auth-box h3 { margin: 0 0 10px 0; }
			.auth-box label { display: block; margin: 8px 0 2px; font-weight: bold; }
			.auth-box input { width: 100%; height: 26px; box-sizing: border-box; padding: 2px 6px; }
			.auth-box button { margin-top: 12px; height: 28px; font-size: 14px; cursor: pointer; }
			.auth-error { color: #b00; margin: 8px 0; font-weight: bold; }
		</style>
	</head>
	<body class="ego_wide canvas center_fixed_width_app fbx UIPage_LoggedOut liquid hideBanner Locale_en_US" style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); overflow: auto;">
		<center><img src="img/logo.png" style="width: 200px;"/></center>
		<div class="mvl ptm uiInterstitial canvas_error_page uiInterstitialLarge uiBoxWhite">
			<div class="uiHeader uiHeaderBottomBorder mhl mts uiHeaderPage interstitialHeader">
				<div class="clearfix uiHeaderTop">
					<div>
						<img src="img/sword.png" height="18px" style="margin-left: 5px;">
						<h2 class="uiHeaderTitle" aria-hidden="true" style="margin-left: 2px; display: inline-block;">
							<a href="/" style="text-decoration: none;">Social Empires </a>
						</h2>
						<p style="display: inline-block; margin: 0 0 4px 6px;">By the Social Emperors team ~ <%= version || "?" %></p>
					</div>
				</div>
			</div>
			<div class="phl ptm uiInterstitialContent" style="overflow: auto;">
				<br>
				<div class="auth-wrap">
					<% if (typeof error !== "undefined" && error) { %>
						<div class="auth-error"><%= error %></div>
					<% } %>

					<!-- LOGIN -->
					<form class="auth-box" method="post" action="/login">
						<h3>Log in</h3>
						<label for="login_user">Username</label>
						<input id="login_user" name="username" type="text" autocomplete="username" required>
						<label for="login_pass">Password</label>
						<input id="login_pass" name="password" type="password" autocomplete="current-password" required>
						<button type="submit">Log in</button>
					</form>

					<!-- REGISTER -->
					<form class="auth-box" method="post" action="/register">
						<h3>Create an account</h3>
						<label for="reg_user">Username <span style="font-weight:normal;">(3-32, letters/digits/_)</span></label>
						<input id="reg_user" name="username" type="text" autocomplete="username" required>
						<label for="reg_empire">Empire name</label>
						<input id="reg_empire" name="empire" type="text" placeholder="My Empire">
						<label for="reg_pass">Password <span style="font-weight:normal;">(min 4 chars)</span></label>
						<input id="reg_pass" name="password" type="password" autocomplete="new-password" required>
						<button type="submit">Create account &amp; empire</button>
					</form>
				</div>
			</div>
		</div>
	</body>
</html>
